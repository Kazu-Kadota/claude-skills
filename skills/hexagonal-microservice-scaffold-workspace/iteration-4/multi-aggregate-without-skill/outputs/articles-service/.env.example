# Application
NODE_ENV=development
PORT=3000
SERVICE_NAME=articles-service

# PostgreSQL (Write DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=articles_db
POSTGRES_USER=articles_user
POSTGRES_PASSWORD=articles_password

# MongoDB (Read DB)
MONGODB_URI=mongodb://localhost:27017/articles_read_db

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka (Event Bus)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=articles-service
KAFKA_GROUP_ID=articles-service-group

# OpenTelemetry
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=articles-service
